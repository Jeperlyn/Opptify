                      "parameters":  {
                                         "jsCode":  "const event = $node[\u0027Get Event\u0027].json.data;const response = $input.first().json;const subscribers = response.data ?? [];const eventDate = new Date(event.event_date);const options = { weekday: \u0027long\u0027, year: \u0027numeric\u0027, month: \u0027long\u0027, day: \u0027numeric\u0027, hour: \u00272-digit\u0027, minute: \u00272-digit\u0027, timeZone: \u0027Asia/Manila\u0027 };const formattedDate = eventDate.toLocaleDateString(\u0027en-US\u0027, options);const isJobFair = event.type === \u0027job_fair\u0027;const eventTypeLabel = isJobFair ? \u0027Job Fair\u0027 : \u0027Employer of the Day\u0027;const badgeColor = isJobFair ? \u0027#0066CC\u0027 : \u0027#FF6B35\u0027;const subject = `${eventTypeLabel}: ${event.title}`;const html = `\u003c!DOCTYPE html\u003e\u003chtml\u003e\u003chead\u003e\u003cmeta charset=\"UTF-8\"\u003e\u003cmeta name=\"viewport\" content=\"width=device-width, initial-scale=1.0\"\u003e\u003c/head\u003e\u003cbody style=\"margin:0;padding:0;font-family:-apple-system,BlinkMacSystemFont,\u0027Segoe UI\u0027,\u0027Helvetica Neue\u0027,Arial,sans-serif;background-color:#f3f4f6\"\u003e\u003ctable role=\"presentation\" style=\"width:100%;border-collapse:collapse\"\u003e\u003ctr\u003e\u003ctd style=\"padding:0\"\u003e\u003ctable role=\"presentation\" style=\"width:100%;border-collapse:collapse;background:linear-gradient(135deg, #667eea 0%, #764ba2 100%)\"\u003e\u003ctr\u003e\u003ctd style=\"padding:24px;text-align:center;color:white\"\u003e\u003ch1 style=\"margin:0;font-size:28px;font-weight:bold\"\u003ePESO Quezon City\u003c/h1\u003e\u003cp style=\"margin:8px 0 0 0;font-size:14px;opacity:0.9\"\u003eEmployment Services\u003c/p\u003e\u003c/td\u003e\u003c/tr\u003e\u003c/table\u003e\u003ctable role=\"presentation\" style=\"width:100%;max-width:600px;margin:0 auto;border-collapse:collapse\"\u003e\u003ctr\u003e\u003ctd style=\"padding:0\"\u003e\u003ctable role=\"presentation\" style=\"width:100%;border-collapse:collapse;background-color:white\"\u003e\u003ctr\u003e\u003ctd style=\"padding:32px 24px\"\u003e\u003cdiv style=\"display:inline-block;background-color:${badgeColor};color:white;padding:6px 12px;border-radius:4px;font-size:12px;font-weight:bold;margin-bottom:16px;text-transform:uppercase;letter-spacing:0.5px\"\u003e${eventTypeLabel}\u003c/div\u003e\u003ch2 style=\"margin:0 0 16px 0;font-size:24px;color:#1f2937;line-height:1.3;font-weight:bold\"\u003e${event.title}\u003c/h2\u003e\u003cp style=\"margin:0 0 24px 0;color:#4b5563;font-size:15px;line-height:1.6\"\u003e${event.description}\u003c/p\u003e\u003ctable role=\"presentation\" style=\"width:100%;border-collapse:collapse;margin:24px 0;border-top:1px solid #e5e7eb;border-bottom:1px solid #e5e7eb\"\u003e\u003ctr\u003e\u003ctd style=\"padding:16px 0;color:#6b7280\"\u003e\u003cp style=\"margin:0 0 12px 0;font-size:13px;font-weight:500;color:#9ca3af\"\u003eDATE \u0026 TIME\u003c/p\u003e\u003cp style=\"margin:0;font-size:16px;color:#1f2937;font-weight:600\"\u003e${formattedDate}\u003c/p\u003e\u003c/td\u003e\u003c/tr\u003e\u003c/table\u003e\u003cdiv style=\"text-align:center;margin:32px 0\"\u003e\u003ca href=\"https://peso.gov.ph\" style=\"display:inline-block;background-color:${badgeColor};color:white;padding:12px 32px;text-decoration:none;border-radius:4px;font-weight:bold;font-size:14px\"\u003eLearn More\u003c/a\u003e\u003c/div\u003e\u003cp style=\"margin:24px 0 0 0;padding-top:24px;border-top:1px solid #e5e7eb;font-size:12px;color:#9ca3af;line-height:1.5\"\u003eThis is an official notification from PESO Quezon City. For more information about our services and upcoming events, please visit our website or contact us.\u003c/p\u003e\u003c/td\u003e\u003c/tr\u003e\u003c/table\u003e\u003c/td\u003e\u003c/tr\u003e\u003c/table\u003e\u003ctable role=\"presentation\" style=\"width:100%;border-collapse:collapse;background-color:#f9fafb;margin-top:0\"\u003e\u003ctr\u003e\u003ctd style=\"padding:24px;text-align:center;font-size:12px;color:#9ca3af\"\u003e\u003cp style=\"margin:0\"\u003ePESO Quezon City | Department of Labor and Employment\u003c/p\u003e\u003cp style=\"margin:8px 0 0 0\"\u003e© 2026 All Rights Reserved\u003c/p\u003e\u003c/td\u003e\u003c/tr\u003e\u003c/table\u003e\u003c/td\u003e\u003c/tr\u003e\u003c/table\u003e\u003c/body\u003e\u003c/html\u003e`;return subscribers.filter((subscriber) =\u003e subscriber.email).map((subscriber) =\u003e ({ json: { toEmail: subscriber.email, subject, html, eventId: event.id, eventType: event.type } }));"
                                     },
